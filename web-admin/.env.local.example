# Copy the ENTIRE content of the service account JSON file you downloaded from
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# and paste it as ONE line here (and as a Vercel Environment Variable of the
# same name). Do not commit the real value — this file is just a template.

FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n", ...}
